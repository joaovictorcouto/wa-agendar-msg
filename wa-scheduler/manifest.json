{
  "manifest_version": 3,
  "name": "WA Scheduler",
  "version": "1.0.0",
  "description": "Automação de mensagens agendadas no WhatsApp Web.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["content/content.js"],
      "css": ["content/style.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Abrir Side Panel do WA Scheduler"
  }
}
